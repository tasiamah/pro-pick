# Base URL of the backend API the app talks to.
# Copy this file to .env (gitignored) for local runs: `cp .env.example .env`.
# Default points at the deployed backend; for a local backend use
# http://localhost:8000. Production builds get this value from eas.json instead.
EXPO_PUBLIC_API_URL=https://pro-pick.onrender.com

# Public URL of the hosted privacy policy (PP-96). Sourced here / from eas.json
# so it can be rotated without an app release. Leave unset to hide the in-app link.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://pro-pick.onrender.com/privacy
