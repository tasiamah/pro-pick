# Copy to .env and adjust.

# App
APP_NAME=VoetbalAI
ENVIRONMENT=development

# Database
# Default: SQLite (zero configuration). For PostgreSQL, for example:
# DATABASE_URL=postgresql+psycopg2://voetbalai:voetbalai@localhost:5432/voetbalai
DATABASE_URL=sqlite:///./voetbalai.db

# External data/odds provider (e.g. API-Football via api-sports.io)
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=

# Value bets
VALUE_BET_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=*
