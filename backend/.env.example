# Kopieer naar .env en pas aan.

# App
APP_NAME=VoetbalAI
ENVIRONMENT=development

# Database
# Standaard: SQLite (nul-configuratie). Voor PostgreSQL, bijvoorbeeld:
# DATABASE_URL=postgresql+psycopg2://voetbalai:voetbalai@localhost:5432/voetbalai
DATABASE_URL=sqlite:///./voetbalai.db

# Externe data-/odds-provider (bijv. API-Football via api-sports.io)
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=

# Value bets
VALUE_BET_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25

# CORS (komma-gescheiden lijst van toegestane origins)
CORS_ORIGINS=*
