# Copy to .env and fill in your values. Never commit .env to git.

# App
APP_NAME=VoetbalAI
ENVIRONMENT=development

# Database (secret — use Supabase Session pooler URI in production)
# Local dev (SQLite, zero-config):
DATABASE_URL=sqlite:///./voetbalai.db

# Local dev with Docker Compose (see docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://voetbalai:voetbalai@localhost:5432/voetbalai
# Optional Docker Compose PostgreSQL overrides (defaults shown):
# POSTGRES_USER=voetbalai
# POSTGRES_PASSWORD=voetbalai
# POSTGRES_DB=voetbalai

# Production — Supabase Session pooler (recommended on IPv4 networks):
# 1. Supabase → Connect → Session pooler → URI
# 2. Replace [YOUR-PASSWORD] with your database password
# 3. Add +psycopg2 after postgresql (required for SQLAlchemy)
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[POOLER-HOST]:5432/postgres

# External football data / odds provider (e.g. API-Football via api-sports.io)
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=
FOOTBALL_API_TIMEOUT_SECONDS=20
FOOTBALL_API_MAX_RETRIES=3
FOOTBALL_API_MIN_REQUEST_INTERVAL_SECONDS=0.6

# Live sync (Premier League, La Liga, FIFA World Cup)
SYNC_LEAGUE_IDS=39,140,1
# Days relative to today to sync fixtures + odds for. -1 settles yesterday's
# finished matches; the forward week gives upcoming fixtures odds ahead of
# kickoff. Each forward day adds ~1 fixtures call + 1 /odds call per match, so
# only widen beyond a few days on a paid API tier (free tier is 100 req/day).
SYNC_DATE_OFFSETS=-1,0,1,2,3,4,5,6,7

# Self-healing settlement: re-fetch matches that kicked off but were never marked
# finished (missed sync run, off-season backlog) by fixture ID, independent of the
# date window above, so they reach the Completed tab. Bounded to protect quota.
SETTLE_OVERDUE_ENABLED=true
SETTLE_OVERDUE_WINDOW_DAYS=14
SETTLE_OVERDUE_MAX_MATCHES=200

# Daily scheduler (disabled by default in local development)
SCHEDULER_ENABLED=false
SCHEDULER_DAILY_HOUR=6
SCHEDULER_IMPORT_ODDS=true

# Value bets
VALUE_BET_EDGE_THRESHOLD=0.02
KELLY_FRACTION=0.25

# Prediction model (leave MODEL_PATH empty to use the default app/ml/model.pkl)
MODEL_ALGORITHM=logistic
MODEL_CALIBRATE=true
MODEL_PATH=
# Periodic retraining via the scheduler (disabled by default)
MODEL_RETRAINING_ENABLED=false
MODEL_RETRAINING_INTERVAL_DAYS=7

# Response caching for heavy endpoints (/analytics, /dashboard); Cache-Control max-age
CACHE_TTL_SECONDS=30

# Rate limiting (per client IP, fixed window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# CORS (comma-separated allowed origins — avoid "*" in committed templates)
# Local Expo / web dev defaults below; set explicit production origins in hosting secrets.
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006

# Push notifications (Expo)
NOTIFICATIONS_ENABLED=true
# Optional Expo access token for higher push rate limits (https://expo.dev/accounts/[account]/settings/access-tokens)
EXPO_ACCESS_TOKEN=
# Required in production to call POST /notifications/test
NOTIFICATION_TEST_SECRET=
# Poll live matches for events every N minutes (requires SCHEDULER_ENABLED=true)
LIVE_NOTIFICATION_POLL_MINUTES=3
SCHEDULER_LIVE_NOTIFICATIONS_ENABLED=true

# Production secrets (set in the host environment, never in git):
# ENVIRONMENT=production
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres
# FOOTBALL_API_KEY=your-api-football-key
