# Copy to .env and fill in your values. Never commit .env to git.

# App
APP_NAME=VoetbalAI
ENVIRONMENT=development

# Database (secret — use Supabase Session pooler URI in production)
# Local dev (SQLite, zero-config):
DATABASE_URL=sqlite:///./voetbalai.db

# Local dev with Docker Compose (see docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://voetbalai:voetbalai@localhost:5432/voetbalai
# Optional Docker Compose PostgreSQL overrides (defaults shown):
# POSTGRES_USER=voetbalai
# POSTGRES_PASSWORD=voetbalai
# POSTGRES_DB=voetbalai

# Production — Supabase Session pooler (recommended on IPv4 networks):
# 1. Supabase → Connect → Session pooler → URI
# 2. Replace [YOUR-PASSWORD] with your database password
# 3. Add +psycopg2 after postgresql (required for SQLAlchemy)
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[POOLER-HOST]:5432/postgres

# External football data / odds provider (e.g. API-Football via api-sports.io)
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=
FOOTBALL_API_TIMEOUT_SECONDS=20
FOOTBALL_API_MAX_RETRIES=3
FOOTBALL_API_MIN_REQUEST_INTERVAL_SECONDS=0.6

# Live sync (free tier: date window + two leagues)
SYNC_LEAGUE_IDS=39,140
SYNC_DATE_OFFSETS=-1,0,1

# Daily scheduler (disabled by default in local development)
SCHEDULER_ENABLED=false
SCHEDULER_DAILY_HOUR=6
SCHEDULER_IMPORT_ODDS=true

# Value bets
VALUE_BET_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25

# CORS (comma-separated allowed origins — avoid "*" in committed templates)
# Local Expo / web dev defaults below; set explicit production origins in hosting secrets.
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006

# Production secrets (set in the host environment, never in git):
# ENVIRONMENT=production
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres
# FOOTBALL_API_KEY=your-api-football-key
